<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RegexTester.ViewModels"
        xmlns:models="using:RegexTester.Models"
        xmlns:conv="using:RegexTester.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:RegexTester.Views"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="RegexTester.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.png"
        Title="Regex Tester"
        MinWidth="700" MinHeight="500"
        Width="1100" Height="780"
        Background="#1a1b2e">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6272a4" />
            <Setter Property="LetterSpacing" Value="1.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="ToggleButton.flag">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Cascadia Code,Fira Code,Consolas,monospace" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#44475a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="#6272a4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ToggleButton.flag:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#383a4a" />
            <Setter Property="TextElement.Foreground" Value="#bd93f9" />
        </Style>
        <Style Selector="ToggleButton.flag:checked">
            <Setter Property="BorderBrush" Value="#bd93f9" />
        </Style>

        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Cascadia Code,Fira Code,Consolas,monospace" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#252637" />
            <Setter Property="Foreground" Value="#f8f8f2" />
            <Setter Property="BorderBrush" Value="#44475a" />
            <Setter Property="CaretBrush" Value="#f8f8f2" />
            <Setter Property="SelectionBrush" Value="#44475a" />
        </Style>
        <Style Selector="TextBox.mono:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#bd93f9" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,5,220">

        <Border Grid.Row="0" Background="#252637" Padding="12,10,12,10">
            <StackPanel Spacing="6">

                <!-- Top row: label / summary / flags -->
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="EXPRESSION" Classes="label" />

                    <TextBlock Grid.Column="1"
                               IsVisible="{Binding !HasError}"
                               Text="{Binding MatchSummary}"
                               Foreground="#50fa7b"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                        <ToggleButton Classes="flag" IsChecked="{Binding IgnoreCase}"
                                      Content="i"
                                      ToolTip.Tip="i — Case Insensitive" />
                        <ToggleButton Classes="flag" IsChecked="{Binding Multiline}"
                                      Content="m"
                                      ToolTip.Tip="m — Multiline (^ and $ match line boundaries)" />
                        <ToggleButton Classes="flag" IsChecked="{Binding Singleline}"
                                      Content="s"
                                      ToolTip.Tip="s — Singleline (dot matches newline)" />
                        <ToggleButton Classes="flag" IsChecked="{Binding IgnorePatternWhitespace}"
                                      Content="x"
                                      ToolTip.Tip="x — Extended (ignore unescaped whitespace in pattern)" />
                    </StackPanel>
                </Grid>

                <!-- Pattern text box -->
                <TextBox Classes="mono"
                         Text="{Binding Pattern}"
                         Watermark="Enter regular expression…"
                         BorderThickness="1"
                         CornerRadius="4"
                         Padding="10,6" />

                <!-- Error display -->
                <Border IsVisible="{Binding HasError}"
                        Background="#2d1515"
                        BorderBrush="#ff5555"
                        BorderThickness="0,0,0,2"
                        CornerRadius="4"
                        Padding="10,5">
                    <TextBlock Text="{Binding RegexError}"
                               Foreground="#ff5555"
                               FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,5,*,5,*">

            <!-- LEFT: Regex Toolbox -->
            <views:RegexToolbox Grid.Column="0"
                               Background="#1a1b2e" />

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#44475a" />

            <!-- MIDDLE: Test String Editor -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#1e1f2e" Padding="12,6">
                    <TextBlock Text="TEST STRING" Classes="label" />
                </Border>
                <TextBox Grid.Row="1"
                         Classes="mono"
                         Text="{Binding TestString}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         Background="#1a1b2e"
                         BorderThickness="0"
                         Padding="12"
                         CornerRadius="0"
                         VerticalContentAlignment="Top"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>

            <GridSplitter Grid.Column="3"
                          ResizeDirection="Columns"
                          Background="#44475a" />

            <!-- RIGHT: Match Information -->
            <Grid Grid.Column="4" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#1e1f2e" Padding="12,6">
                    <TextBlock Text="MATCH INFORMATION" Classes="label" />
                </Border>
                <ScrollViewer Grid.Row="1"
                              Background="#1a1b2e"
                              Padding="6,4"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LineResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:LineResult">
                                <Border Margin="0,1"
                                        CornerRadius="4"
                                        Padding="8,5"
                                        Background="{Binding HasMatch,
                                            Converter={x:Static conv:ValueConverters.MatchRowBackground}}">
                                    <StackPanel Spacing="2">
                                        <!-- ...existing code... -->
                                        <Grid ColumnDefinitions="14,30,*">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HasMatch,
                                                           Converter={x:Static conv:ValueConverters.MatchDotText}}"
                                                       Foreground="{Binding HasMatch,
                                                           Converter={x:Static conv:ValueConverters.MatchDotBrush}}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LineNumber}"
                                                       Foreground="#6272a4"
                                                       FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                                                       FontSize="11"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       Padding="0,1,8,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding LineText}"
                                                       Foreground="#f8f8f2"
                                                       FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Top" />
                                        </Grid>
                                        <!-- ...existing code... -->
                                        <ItemsControl ItemsSource="{Binding Matches}"
                                                      IsVisible="{Binding HasMatch}"
                                                      Margin="24,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:MatchResult">
                                                    <StackPanel Spacing="2" Margin="0,2,0,0">
                                                        <!-- ...existing code... -->
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="Match"
                                                                       Foreground="#6272a4"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center" />
                                                            <Border Background="#162b1c"
                                                                    BorderBrush="#50fa7b"
                                                                    BorderThickness="0,0,0,1"
                                                                    CornerRadius="3"
                                                                    Padding="5,1">
                                                                <TextBlock Text="{Binding Value}"
                                                                           Foreground="#50fa7b"
                                                                           FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                                                                           FontSize="13" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Index, StringFormat='@ {0}'}"
                                                                       Foreground="#44475a"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <!-- ...existing code... -->
                                                        <ItemsControl ItemsSource="{Binding Groups}"
                                                                      Margin="12,0,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="models:GroupResult">
                                                                    <StackPanel Orientation="Horizontal"
                                                                            Spacing="6"
                                                                            IsVisible="{Binding Success}"
                                                                            Margin="0,1">
                                                                        <TextBlock
                                                                            Text="{Binding Name, StringFormat='Group {0}'}"
                                                                            Foreground="#6272a4"
                                                                            FontSize="11"
                                                                            VerticalAlignment="Center" />
                                                                        <Border Background="#2a2714"
                                                                                BorderBrush="#f1fa8c"
                                                                                BorderThickness="0,0,0,1"
                                                                                CornerRadius="3"
                                                                                Padding="5,1">
                                                                            <TextBlock Text="{Binding Value}"
                                                                                    Foreground="#f1fa8c"
                                                                                    FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                                                                                    FontSize="13" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Horizontal splitter -->
        <GridSplitter Grid.Row="2"
                      ResizeDirection="Rows"
                      Background="#44475a"
                      Height="5" />

        <Grid Grid.Row="3" RowDefinitions="Auto,*"
              MinHeight="80"
              Background="#252637">

            <!-- Header bar -->
            <Border Grid.Row="0" Background="#1e1f2e" Padding="12,6">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="EXPLANATION" Classes="label" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <!-- Building spinner (simple text pulse) -->
                        <TextBlock IsVisible="{Binding IsExplaining}"
                                   Text="compiling scratch project…"
                                   Foreground="#6272a4"
                                   FontSize="11" />
                    </StackPanel>

                    <!-- Explain now button -->
                    <Button Grid.Column="3"
                            Command="{Binding ExplainNowCommand}"
                            IsEnabled="{Binding !IsExplaining}"
                            Content="Explain now"
                            Background="#383a4a"
                            Foreground="#f8f8f2"
                            BorderBrush="#6272a4"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,4"
                            FontSize="12"
                            Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Explanation content -->
            <ScrollViewer Grid.Row="1" Padding="12,8">
                <StackPanel Spacing="4">

                    <!-- Error -->
                    <TextBlock Text="{Binding ExplanationError}"
                               IsVisible="{Binding ExplanationError,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="#ff5555"
                               FontSize="12"
                               TextWrapping="Wrap" />

                    <!-- Lines -->
                    <ItemsControl ItemsSource="{Binding ExplanationLines}"
                                  IsVisible="{Binding HasExplanation}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ExplanationLine">
                                <TextBlock Text="{Binding Text}"
                                           Foreground="#f8f8f2"
                                           FontFamily="Cascadia Code,Fira Code,Consolas,monospace"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="{Binding IndentLevel,
                                               Converter={x:Static conv:ValueConverters.Indent}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock IsVisible="{Binding !HasExplanation}"
                               IsEnabled="{Binding !IsExplaining}"
                               Text="Explanation will appear here after a pattern is entered. It uses dotnet's GeneratedRegex source generator internally."
                               Foreground="#44475a"
                               FontSize="12"
                               TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>

</Window>